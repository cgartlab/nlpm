#!/usr/bin/env python3
"""Extract a project's vocabulary skill into the VocabularyData JSON shape.

Reads a registry.yaml (per the schema in skills/nlpm/vocabulary/registry.yaml)
and emits the JSON the noun-verb map Vue component consumes. See
analysis/report-data-schema.md for the VocabularyData contract.

Edges (verb → noun) are inferred:
  - Each verb's `output:` text is matched against canonical noun ids;
    matches become 'produces' edges.
  - Each role-noun's `paired_verb` becomes an 'acts_as' edge from the
    paired verb to the role-noun.

PyYAML required. (PyYAML is available in our local dev environment and
in the auditor CI workflows that need to call this script.)

Usage:
    python3 bin/nlpm-build-vocab-data \\
        --registry skills/nlpm/vocabulary/registry.yaml \\
        --out      /tmp/nlpm-vocab.json
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    print("error: PyYAML required (pip install pyyaml)", file=sys.stderr)
    sys.exit(2)


def build_vocab_data(registry_path: Path) -> dict:
    reg = yaml.safe_load(registry_path.read_text(encoding="utf-8"))

    scopes = []
    for s in reg.get("scopes", []) or []:
        scopes.append({"id": s["id"], "label": s["id"].capitalize()})

    verbs = []
    for scope_id, items in (reg.get("verbs") or {}).items():
        for v in items or []:
            verbs.append({
                "id": v["canonical"],
                "scope": scope_id,
                "deprecated": v.get("deprecated") or [],
                "judgment": bool(v.get("judgment", False)),
                "output": v.get("output", ""),
            })

    nouns = []
    role_pairings: list[tuple[str, str]] = []  # (verb_id, role_noun_id) for edges
    for cls, items in (reg.get("nouns") or {}).items():
        for n in items or []:
            if not isinstance(n, dict):
                continue
            nid = n.get("canonical") or n.get("paired_verb") or ""
            if not nid:
                continue
            entry = {
                "id": nid,
                "class": cls,
                "definition": n.get("definition", ""),
                "scope": n.get("scope"),
            }
            nouns.append(entry)
            if cls == "role_nouns" and n.get("paired_verb"):
                role_pairings.append((n["paired_verb"], nid))

    # Edges:
    # 1. produces — each verb whose `output:` text mentions a canonical noun
    # 2. acts_as — each role-noun gets an edge from its paired verb
    noun_ids = {n["id"] for n in nouns}
    edges = []
    for v in verbs:
        out = (v.get("output") or "").lower()
        for nid in noun_ids:
            if nid.lower() in out:
                edges.append({"source": v["id"], "target": nid, "type": "produces"})
    for verb_id, role_id in role_pairings:
        edges.append({"source": verb_id, "target": role_id, "type": "acts_as"})

    cross_scope = (reg.get("cross_scope_homonyms") or {}).get("verbs") or []

    deferred = []
    for entry in reg.get("deferred_pending_warrant") or []:
        if not isinstance(entry, dict):
            continue
        deferred.append({
            "verb": entry.get("verb", ""),
            "scope": entry.get("scope", "internal"),
            "needed_warrant": entry.get("needed_warrant", ""),
        })

    return {
        "scopes": scopes,
        "verbs": verbs,
        "nouns": nouns,
        "edges": edges,
        "cross_scope_homonyms": cross_scope,
        "deferred": deferred,
    }


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__.split("\n\n")[0])
    parser.add_argument("--registry", required=True, help="Path to registry.yaml")
    parser.add_argument("--out", help="Path to write VocabularyData JSON (default: stdout)")
    args = parser.parse_args(argv)

    reg_path = Path(args.registry).resolve()
    if not reg_path.exists():
        print(f"error: registry not found: {reg_path}", file=sys.stderr)
        return 2

    data = build_vocab_data(reg_path)
    out_text = json.dumps(data, ensure_ascii=False, indent=2)

    if args.out:
        Path(args.out).write_text(out_text + "\n", encoding="utf-8")
        print(f"Wrote {args.out}")
        print(f"  scopes: {len(data['scopes'])}")
        print(f"  verbs: {len(data['verbs'])}  (internal: {sum(1 for v in data['verbs'] if v['scope']=='internal')}, auditor: {sum(1 for v in data['verbs'] if v['scope']=='auditor')})")
        print(f"  nouns: {len(data['nouns'])}")
        print(f"  edges: {len(data['edges'])}")
        print(f"  cross-scope homonyms: {data['cross_scope_homonyms']}")
        print(f"  deferred: {len(data['deferred'])}")
    else:
        print(out_text)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
