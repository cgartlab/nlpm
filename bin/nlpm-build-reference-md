#!/usr/bin/env python3
"""Build VitePress-shaped Markdown reference pages from canonical sources.

Reads (same as bin/nlpm-build-docs):
  - skills/nlpm/rules/SKILL.md
  - analysis/vocabulary-design-principles.md
  - skills/nlpm/vocabulary/SKILL.md
  - skills/nlpm/scoring/SKILL.md
  - skills/nlpm/conventions/SKILL.md
  - agents/vocab-drift-scanner.md

Emits one .md file per topic into <out>/:
  rules.md, principles.md, vocabulary.md, scoring.md,
  artifact-types.md, drift.md

Each rule/principle/concept gets an explicit anchor id so the URL
fragments are stable contracts (e.g. /reference/rules#R06 stays valid).
VitePress's markdown-it picks up the `{#R06}` annotation on headings.

Stdlib only.

Usage:
  python3 bin/nlpm-build-reference-md --out site/reference/
"""
from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]


def read_text(path: Path) -> str:
    """Read a canonical source file. Missing files raise loudly.

    Earlier this returned "" on missing paths, which let
    nlpm-build-reference-md succeed with empty section bodies — site
    reference pages would publish with the section heading but no
    content. Every caller below reads a known-canonical SKILL.md (or
    similar) that must exist; if a future caller wants optional
    behavior, it should branch on path.exists() explicitly.
    """
    if not path.exists():
        raise FileNotFoundError(
            f"canonical source missing: {path} — nlpm-build-reference-md "
            f"cannot generate a reference page without it"
        )
    return path.read_text(encoding="utf-8")


def split_frontmatter(text: str) -> str:
    if not text.startswith("---"):
        return text
    parts = text.split("---", 2)
    return parts[2] if len(parts) >= 3 else text


def slugify(s: str) -> str:
    s = s.lower()
    s = re.sub(r"[^a-z0-9]+", "-", s)
    return s.strip("-")


# ---------------------------------------------------------------------------
# Per-topic emitters — output VitePress-compatible Markdown.
# ---------------------------------------------------------------------------

def emit_rules() -> str:
    text = split_frontmatter(read_text(ROOT / "skills" / "nlpm" / "rules" / "SKILL.md"))
    pattern = re.compile(
        r"^\*\*(R\d+)\.\s+([^*]+?)\.\*\*\s*(.+?)(?=^\*\*R\d+\.\s|^##\s|^---\s*$|\Z)",
        re.M | re.S,
    )
    out = [
        "---",
        "title: Rules (R01–R51)",
        "outline: [2, 3]",
        "---",
        "",
        "# The Rules of Natural Language Programming",
        "",
        "51 rules covering universal NL artifact quality, plus per-artifact-type "
        "constraints (skills, agents, commands, rules, hooks, plugins). "
        "Findings in NLPM reports link to the specific rule they triggered.",
        "",
    ]
    for m in pattern.finditer(text):
        rid = m.group(1)
        title = m.group(2).strip()
        body = m.group(3).rstrip()
        out.append(f"## {rid} — {title} {{#{rid}}}")
        out.append("")
        out.append(body)
        out.append("")
    # Append the warrant table verbatim — it already exists as a clean
    # markdown section in the source.
    warrant_m = re.search(
        r"^## Warrant tags.*?\n+(.+?)(?=^## |\Z)",
        text,
        re.M | re.S,
    )
    if warrant_m:
        out.append("## Warrant tags {#warrant-types}")
        out.append("")
        out.append(warrant_m.group(1).rstrip())
        out.append("")
    return "\n".join(out)


def emit_principles() -> str:
    text = read_text(ROOT / "analysis" / "vocabulary-design-principles.md")
    out = [
        "---",
        "title: Vocabulary design principles",
        "outline: [2, 3]",
        "---",
        "",
        "# Vocabulary Design Principles",
        "",
        "Six principles that govern controlled-vocabulary work in NLPM. "
        "Copied from `eou-foundry/dev-docs/04-vocabulary-principles.md`, "
        "battle-tested against OntoClean, DDD, ISO 25964, and BPMN/Event Storming.",
        "",
    ]
    # Per-principle slicing
    for m in re.finditer(
        r"^### (P\d+) — ([^\n]+)\n+(.+?)(?=^### P\d+ — |^## |\Z)",
        text,
        re.M | re.S,
    ):
        pid = m.group(1)
        title = m.group(2).strip()
        body = m.group(3).rstrip()
        out.append(f"## {pid} — {title} {{#{pid}}}")
        out.append("")
        out.append(body)
        out.append("")
    # Precedence section
    prec = re.search(
        r"^## Conflict resolution: precedence order\n+(.+?)(?=^## |\Z)",
        text,
        re.M | re.S,
    )
    if prec:
        out.append("## Conflict resolution: precedence order {#precedence}")
        out.append("")
        out.append(prec.group(1).rstrip())
        out.append("")
    return "\n".join(out)


def emit_vocabulary() -> str:
    text = split_frontmatter(read_text(ROOT / "skills" / "nlpm" / "vocabulary" / "SKILL.md"))
    out = [
        "---",
        "title: Vocabulary concepts",
        "outline: [2, 3]",
        "---",
        "",
        "# NLPM Domain Vocabulary",
        "",
        "Canonical noun and verb registry across NLPM's two scopes (internal "
        "and auditor), plus the bright-line evaluation cluster and the "
        "deferred-vs-rejected split per the P6 precedence order.",
        "",
    ]
    # Slice every H2 section
    h2_iter = list(re.finditer(r"^## (.+?)$", text, re.M))
    for idx, m in enumerate(h2_iter):
        title = m.group(1).strip()
        start = m.end()
        end = h2_iter[idx + 1].start() if idx + 1 < len(h2_iter) else len(text)
        body = text[start:end].rstrip()
        anchor = "vocab-" + slugify(title)
        out.append(f"## {title} {{#{anchor}}}")
        out.append("")
        out.append(body)
        out.append("")
    return "\n".join(out)


def emit_scoring() -> str:
    text = split_frontmatter(read_text(ROOT / "skills" / "nlpm" / "scoring" / "SKILL.md"))
    out = [
        "---",
        "title: Scoring & severity",
        "outline: [2, 3]",
        "---",
        "",
        "# Scoring & Severity",
        "",
        "How the 100-point rubric maps to score bands and how the scorer "
        "assigns severity levels to findings.",
        "",
    ]
    bands = re.search(r"^## Score Bands\n+(.+?)(?=^## |\Z)", text, re.M | re.S)
    if bands:
        out.append("## Score bands {#score-bands}")
        out.append("")
        out.append(bands.group(1).rstrip())
        out.append("")
    out.append("## Severity levels {#severity-levels}")
    out.append("")
    out.append(
        "| Severity | Local scorer | Auditor schema |\n"
        "|----------|--------------|----------------|\n"
        "| **HIGH** | penalty ≥ 10 points | scorer reproduced the breakage during the scoring pass; `confidence: high`, requires concrete `evidence`. Only HIGH findings reach the contribute step. |\n"
        "| **MEDIUM** | penalty 5–9 points | default confidence; no reproducer required. |\n"
        "| **LOW** | penalty < 5 points | weakest signal; kept for our own learning but not for PRs. |"
    )
    out.append("")
    return "\n".join(out)


def emit_artifact_types() -> str:
    text = split_frontmatter(read_text(ROOT / "skills" / "nlpm" / "conventions" / "SKILL.md"))
    out = [
        "---",
        "title: Artifact types",
        "outline: [2, 3]",
        "---",
        "",
        "# Artifact Types",
        "",
        "Every NL programming artifact NLPM scores. Each row in a report's "
        "*type* column maps to one section below.",
        "",
    ]
    # Top-level "## N. Foo" headings in the conventions skill
    h2_iter = list(re.finditer(r"^## \d+\.\s+(.+?)$", text, re.M))
    for idx, m in enumerate(h2_iter):
        title = m.group(1).strip()
        start = m.end()
        end = h2_iter[idx + 1].start() if idx + 1 < len(h2_iter) else len(text)
        body = text[start:end].rstrip()
        anchor = "artifact-" + slugify(title)
        out.append(f"## {title} {{#{anchor}}}")
        out.append("")
        out.append(body)
        out.append("")
    return "\n".join(out)


def emit_drift() -> str:
    text = split_frontmatter(read_text(ROOT / "agents" / "vocab-drift-scanner.md"))
    out = [
        "---",
        "title: Drift criteria",
        "outline: [2, 3]",
        "---",
        "",
        "# Drift Dispositions & Confidence",
        "",
        "How the `vocab-drift-scanner` agent classifies candidate "
        "synonym clusters when running on a corpus without a declared registry.",
        "",
    ]
    judge = re.search(
        r"### Step 4: Judge each cluster\n+(.+?)(?=^### |\Z)",
        text,
        re.M | re.S,
    )
    if judge:
        out.append("## Disposition criteria {#disposition-criteria}")
        out.append("")
        out.append(judge.group(1).rstrip())
        out.append("")
    out.append("## Confidence levels {#confidence-criteria}")
    out.append("")
    out.append(
        "| Confidence | What it means |\n"
        "|------------|---------------|\n"
        "| **high** | Surface similarity + role compatibility + ≥ 60% co-occurrence overlap. Strong recommendation to declare a canonical. |\n"
        "| **medium** | Surface similarity + role compatibility, but co-occurrence overlap below 60%; or surface dissimilar but role + neighbors match. Worth a maintainer's review. |\n"
        "| **low** | Mixed signals; the scanner can't tell from the corpus alone. Treat as a hint, not a directive. |"
    )
    out.append("")
    return "\n".join(out)


def emit_reference_index() -> str:
    return """---
title: Framework reference
---

# Framework Reference

NLPM's full conceptual surface, anchored.

## In this section

- [Rules R01–R51](./rules) — every rule the scorer can fire, with bad/good examples and warrant tags.
- [Vocabulary principles P1–P6](./principles) — the six principles that govern controlled-vocabulary work, plus the conflict-resolution precedence order.
- [Vocabulary concepts](./vocabulary) — scopes, canonical noun/verb tables, cross-scope homonyms, the deferred-vs-rejected split.
- [Scoring & severity](./scoring) — 100-point bands and severity calibration.
- [Artifact types](./artifact-types) — schemas for every artifact kind NLPM scores.
- [Drift criteria](./drift) — how the `vocab-drift-scanner` judges clusters.

## How to use this

Every NLPM report links into these pages by anchor. Click a finding's rule_id badge to land directly on the rule's section. Click a severity badge to see how the scorer assigns HIGH/MEDIUM/LOW. Click a vocabulary node in the noun-verb map to land on its concept definition.
"""


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__.split("\n\n")[0])
    parser.add_argument("--out", required=True, help="Output directory (will contain rules.md, etc.)")
    args = parser.parse_args(argv)

    out_dir = Path(args.out).resolve()
    out_dir.mkdir(parents=True, exist_ok=True)

    pages = {
        "index.md": emit_reference_index(),
        "rules.md": emit_rules(),
        "principles.md": emit_principles(),
        "vocabulary.md": emit_vocabulary(),
        "scoring.md": emit_scoring(),
        "artifact-types.md": emit_artifact_types(),
        "drift.md": emit_drift(),
    }
    for name, body in pages.items():
        (out_dir / name).write_text(body, encoding="utf-8")
    print(f"Wrote {len(pages)} pages to {out_dir}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
